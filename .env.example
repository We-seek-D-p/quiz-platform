DB_HOST=db
DB_PORT=5432
DB_NAME=quiz
DB_USER=quiz_app
DB_PASSWORD=quiz_password

NGINX_APP_PORT=8080

AUTH_APP_NAME="Quiz Auth"
AUTH_APP_PORT=8000
AUTH_DEBUG=false
AUTH_DATABASE_URL=postgresql+asyncpg://quiz_app:quiz_password@db:5432/quiz
AUTH_JWT_SECRET_KEY=replace-with-at-least-32-characters
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=5
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_SECURE=false

MANAGEMENT_APP_NAME="Quiz Management"
MANAGEMENT_APP_PORT=8000
MANAGEMENT_DEBUG=false
MANAGEMENT_DATABASE_URL=postgresql+asyncpg://quiz_app:quiz_password@db:5432/quiz
MANAGEMENT_INTERNAL_SERVICE_NAME=management
MANAGEMENT_INTERNAL_ALLOWED_SERVICES=session
MANAGEMENT_INTERNAL_TOKEN=replace-with-management-internal-token

SESSION_APP_NAME="Quiz Session"
SESSION_APP_PORT=8000

SESSION_LOG_LEVEL=info
SESSION_LOG_FORMAT=json

SESSION_REDIS_ADDR=redis:6379
SESSION_REDIS_PASSWORD=
SESSION_REDIS_DB=0

SESSION_INTERNAL_SERVICE_NAME=session
SESSION_INTERNAL_ALLOWED_SERVICES=management
SESSION_INTERNAL_TOKEN=replace-with-session-internal-token

SESSION_MANAGEMENT_BASE_URL=http://management:8000
SESSION_MANAGEMENT_TIMEOUT_SECONDS=5
SESSION_MANAGEMENT_INTERNAL_TOKEN=replace-with-management-internal-token

SESSION_WS_READ_LIMIT_BYTES=65536

SESSION_GAME_REVEAL_DURATION_SECONDS=5
