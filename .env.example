DB_HOST=db
DB_PORT=5432
DB_NAME=quiz
DB_USER=quiz_app
DB_PASSWORD=quiz_password

NGINX_APP_PORT=8080

AUTH_APP_NAME="Quiz Auth"
AUTH_APP_PORT=8000
AUTH_DEBUG=false
AUTH_DATABASE_URL=postgresql+asyncpg://quiz_app:quiz_password@db:5432/quiz
AUTH_JWT_SECRET_KEY=replace-with-at-least-32-characters
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=5
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_SECURE=false

MANAGEMENT_APP_NAME="Quiz Management"
MANAGEMENT_APP_PORT=8000
MANAGEMENT_DEBUG=false
MANAGEMENT_DATABASE_URL=postgresql+asyncpg://quiz_app:quiz_password@db:5432/quiz
