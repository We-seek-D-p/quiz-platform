set dotenv-load
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

APP := "session-service"
BIN_DIR := "bin"
BIN := BIN_DIR + "/" + APP
CMD := "./cmd/session-service"

# List recipes
[default]
[private]
default:
    @just --list --unsorted

# Download Go dependencies
install:
    go mod download

# Format and tidy Go code
fmt:
    gofmt -w .
    go mod tidy

# Run go vet checks
vet:
    go vet ./...

# Run golangci-lint
lint:
    golangci-lint run ./...

# Run Go tests
test:
    go test ./...

# Build service binary
build:
    mkdir -p {{ BIN_DIR }}
    go build -o {{ BIN }} {{ CMD }}

# Run service locally
run:
    go run {{ CMD }}

# Check Go code and run tests
check:
    test -z "$(gofmt -l .)"
    go vet ./...
    golangci-lint run ./...
    go test ./...
